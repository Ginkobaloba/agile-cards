# OS
Thumbs.db
.DS_Store
desktop.ini

# Secrets. A real API key in a committed .env file is a credential
# leak. The runner reads ANTHROPIC_API_KEY straight from the process
# environment, never from a .env file, but ignore the pattern anyway.
.env
.env.*

# Editors
.vscode/
.idea/
*.swp
*~

# Sync-tool detritus
.synctest.*
*.tmp
*.bak

# Test outputs
tests/cards-rename-test/
*.log

# Python / node detritus if local tooling shows up later
__pycache__/
*.pyc
.venv/
node_modules/
.pytest_cache/

# Card store files. The runner's SQLite store (and Dolt's storage
# dir) live outside the repo by design; never commit one if it lands
# inside the tree during local runs.
*.db
*.db-wal
*.db-shm
*.sqlite

# Runtime data lives outside this repo by design.
# If you ever symlink the runtime dir in here for convenience, ignore it.
todo/
_batches/

##########################
# Probe / Claude / Python build artifacts (added 2026-05-29 per retro auto-actionable batch)
##########################
.claude/
**/*.egg-info/
.tmp_*
.size_test
.write_test
